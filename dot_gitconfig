[core]
	excludesfile = /home/taminomara/.gitignore
	autocrlf = input
[user]
	name = Tamika Nomara
	email = taminomara@gmail.com
	signingkey = CC37CA45A110C66D7EF6CD8B9B186505F6CFE03C
[commit]
	gpgsign = true
[alias]
	graph = gr
	gr = log --graph --format=format:'%C(blue)%h%C(reset) %C(green)(%ar)%C(reset) %C(bold white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)'
	st = status
	co = checkout
	ci = commit
	cim = commit -m
	cia = commit --amend --no-edit
	br = branch
	sw = switch
	aa = add -A
	p = push
	pf = push --force-with-lease
	sp = stash push
	spp = stash pop
	wip = !bash ~/.gitcommands/wip.bash
	unwip = !bash ~/.gitcommands/unwip.bash
	sww = !bash ~/.gitcommands/sww.bash
[push]
	autoSetupRemote = true
[pull]
	ff = only
[init]
	defaultBranch = main
[diff]
	algorithm = histogram
	indentHeuristic = true
	renames = copies
	colorMoved = plain
	mnemonicPrefix = true
[rebase]
	autosquash = true
	autoStash = true
[fetch]
	all = true
	prune = true
	pruneTags = false
[rerere]
	enabled = true
	autoUpdate = true

[merge]
	tool = vimdiff
	conflictstyle = diff3
[mergetool]
	prompt = false
[blame]
	ignoreRevsFile = 
[includeIf "gitdir:~/p/cloudlinux/"]
    path = ~/p/cloudlinux/.gitconfig
